  document.addEventListener('DOMContentLoaded', () => {
    // Request Modifiers
    // Docs: https://docs.klevu.com/template-js/modify-search-query

    /* This modifier suppies image urls to the returned CMS results data,
     * without this, images will be returned as an empty string */
    klevu.modifyRequest('quick', (data, scope) => {
      klevu.setObjectPath(data, 'localOverrides.query.cmsCompressed.settings.fields', [
        'id',
        'name',
        'shortDesc',
        'url',
        'typeOfRecord',
        'image', // Custom
      ]);
    });
  });
