{%- liquid
  # Customised Templates
  # -- -- -- -- -- -- -- -- -- -- --

  # -- Quick Search -- #
  render 'klevu_custom-klevuQuickAutoSuggestions'
  render 'klevu_custom-klevuQuickCategorySuggestions'
  render 'klevu_custom-klevuQuickImageSearchContent'
  render 'klevu_custom-klevuQuickNoResultsFoundBanners'
  render 'klevu_custom-klevuQuickNoResultsPopularProductBlock'
  render 'klevu_custom-klevuQuickNoResultsPopularProducts'
  render 'klevu_custom-klevuQuickOtherContent'
  render 'klevu_custom-klevuQuickPageSuggestions'
  render 'klevu_custom-klevuQuickProductBlock'
  render 'klevu_custom-klevuQuickProductBlockTitleHeader'
  render 'klevu_custom-klevuQuickProductRating'
  render 'klevu_custom-klevuQuickProductRatingCount'
  render 'klevu_custom-klevuQuickProducts'
  render 'klevu_custom-klevuQuickPromotionBanner'
  render 'klevu_custom-klevuQuickRecentViewedProductBlock'
  render 'klevu_custom-klevuQuickTemplateBase'
  render 'klevu_custom-klevuQuickTemplateContentBlock'
  render 'klevu_custom-klevuQuickTemplateFilters'
  render 'klevu_custom-klevuQuickTemplateInfiniteScrollDown'
  render 'klevu_custom-klevuQuickTemplatePagination'
  render 'klevu_custom-klevuQuickTemplateResultsHeadingTitle'
  render 'klevu_custom-klevuQuickTemplateSortBy'
  render 'klevu_custom-klevuQuickTemplateTabResults'
  render 'klevu_custom-klevuQuickTrendingProductBlock'
  render 'klevu_custom-klevuRecentViewedProducts'
  render 'klevu_custom-klevuSearchPersonalizations'
  render 'klevu_custom-klevuTemplateNoResultFoundQuick'
  render 'klevu_custom-klevuTrendingProducts'
  render 'klevu_custom-kuQuickNoResultsPopularSearches'
  render 'klevu_custom-kuTemplatePopularSearches'
  render 'klevu_custom-kuTemplateQuickResultsViewSwitch'
  render 'klevu_custom-kuTemplateRecentSearches'
  render 'klevu_custom-quickSearchProductAddToCart'
  render 'klevu_custom-quickSearchResultProductStock'
  render 'klevu_custom-searchResultProductVATLabelQuick'

  # -- Search Landing -- #
  assign is_search_landing = false
  case template.suffix
    when 'klevu-search', 'search'
      assign is_search_landing = true
  endcase

  if is_search_landing
    render 'klevu_custom-klevuLandingImageSearchUploadBanner'
    render 'klevu_custom-klevuLandingNoResultsFoundBanners'
    render 'klevu_custom-klevuLandingProductRating'
    render 'klevu_custom-klevuLandingProductRatingCount'
    render 'klevu_custom-klevuLandingPromotionBanner'
    render 'klevu_custom-klevuLandingTemplateBase'
    render 'klevu_custom-klevuLandingTemplateContentBlock'
    render 'klevu_custom-klevuLandingTemplateFilters'
    render 'klevu_custom-klevuLandingTemplateInfiniteScrollDown'
    render 'klevu_custom-klevuLandingTemplateNoResultFound'
    render 'klevu_custom-klevuLandingTemplatePagination'
    render 'klevu_custom-klevuLandingTemplateProductBlock'
    render 'klevu_custom-klevuLandingTemplateResults'
    render 'klevu_custom-klevuLandingTemplateResultsHeadingTitle'
    render 'klevu_custom-klevuLandingTemplateSearchBar'
    render 'klevu_custom-klevuLandingTemplateSortBy'
    render 'klevu_custom-klevuLandingTemplateTabResults'
    render 'klevu_custom-klevuLandingTemplateTopFilters'
    render 'klevu_custom-klevuNoResultsPopularProductsLanding'
    render 'klevu_custom-kuFilterTagsTemplate'
    render 'klevu_custom-kuNoResultsPopularSearchesLanding'
    render 'klevu_custom-kuTemplateLandingResultsViewSwitch'
    render 'klevu_custom-landingImageRollover'
    render 'klevu_custom-landingPageProductAddToCart'
    render 'klevu_custom-landingPageProductColorSwatches'
    render 'klevu_custom-landingQuickViewImageRollover'
    render 'klevu_custom-landingSearchResultProductStock'
    render 'klevu_custom-quickViewProductColorSwatches'
    render 'klevu_custom-searchResultProductBadge'
    render 'klevu_custom-searchResultProductVATLabel'
  endif
-%}
