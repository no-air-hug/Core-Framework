<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- liquid
      # theme-check-disable
      echo content_for_header
      # theme-check-enable

      render 'theme_head'
      render 'theme_seo'

      echo settings.head_scripts

      # Template Classes
      capture template_class
        assign template_name = template.name | prepend: 'template-'

        if template.suffix != blank
          assign template_name = template_name | append: '-' | append: template.suffix
        endif

        echo template_name
      endcapture

      # Include webpack import map
      render 'theme_assets', import_map: true

      # Include webpack main entrypoints
      render 'theme_assets' with 'main.min.js', preload: true
      render 'theme_assets' with 'main.min.css', preload: true
    -%}
  </head>

  <body
    class="{{ template_class }}"
    itemtype="http://schema.org/WebPage"
    itemscope
    {% if request.design_mode %}
      data-is-design-mode
    {% endif %}
  >
    <a class="sr-only" href="#MainContent">{{ 'global.accessibility.skip_to_text' | t }}</a>

    <header class="header-group js-header-group">
      {%- sections 'header-minimal-group' -%}
    </header>

    <main
      id="MainContent"
      tabindex="-1"
    >
      {{ content_for_layout }}
    </main>

    <footer class="footer-group">
      {%- sections 'footer-minimal-group' -%}
    </footer>

    <aside class="dialog-group">
      {%- sections 'dialog-group' -%}
    </aside>

    <ul hidden>
      <li id="a11y-refresh-page-message">{{- 'global.accessibility.refresh_page' | t -}}</li>
    </ul>

    {{- settings.body_scripts -}}
  </body>
</html>
