  },
  {
    "name": "Custom scripts",
    "settings": [
      {
        "type": "header",
        "content": "Scripts for tracking and analytics"
      },
      {
        "type": "liquid",
        "id": "head_scripts",
        "label": "Scripts for site head"
      },
      {
        "type": "liquid",
        "id": "body_scripts",
        "label": "Scripts for site body"
      }
    ]
  },
  {
    "name": "Yotpo",
    "settings": [
      {
        "type": "header",
        "content": "Widget Instances",
        "info": "ID's located on Yotpo Widget Editor URL: https://yap.yotpo.com/wadmin/#/reviews-star-ratings/widget/instance_id"
      },
      {
        "type": "text",
        "id": "yotpo_star_rating_instance",
