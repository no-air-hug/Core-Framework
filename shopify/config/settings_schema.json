  {
    "name": "Product",
    "settings": [
      {
        "type": "select",
        "id": "enable_lightbox",
        "options": [
          {
            "value": "false",
            "label": "Disable"
          },
          {
            "value": "true",
            "label": "Enable"
          }
        ],
        "default": "true",
        "label": "Lightbox and Image Zoom"
      }
    ]
  },
  {
    "name": "Product Card",
    "settings": [
      {
        "type": "header",
        "content": "Quick Shop"
      },
      {
        "type": "checkbox",
        "id": "enable_quick_shop",
        "default": true,
        "label": "Enable Quick Shop"
      },
      {
        "type": "checkbox",
        "id": "show_product_variants",
        "default": false,
        "label": "Show variant images on product cards"
      }
    ]
  },
  {
    "name": "Markets",
    "settings": [
      {
        "type": "header",
        "content": "Markets"
      },
      {
        "type": "checkbox",
        "id": "enable_markets",
        "label": "Enable Markets UI",
        "default": false
      }
    ]
  },
  {
    "name": "Free delivery",
    "settings": [
      {
        "type": "number",
        "id": "free_delivery_threshold",
        "default": 0,
        "label": "Threshold",
        "info": "Minimum order value for free delivery, in pence. i.e. 1000 = £10"
      }
    ]
  },
  {
    "name": "Delivery estimate",
    "settings": [
      {
        "type": "checkbox",
        "id": "estimate_delivery_enabled",
        "label": "Enabled?",
        "default": false
      },
      {
        "type": "text",
        "id": "estimate_delivery_cutoff",
        "label": "Delivery cutoff time",
        "default": "13:00",
        "info": "Cutoff time in HH:MM format."
      },
      {
        "type": "textarea",
        "id": "estimate_delivery_excluded_dates",
        "label": "Excluded dates",
        "info": "Comma separated list of dates (e.g. Christmas) in DD/MM/YYYY format."
      }
    ]
  },
  {
    "name": "Sitewide Search Method",
    "settings": [
      {
        "type": "select",
        "id": "sitewide_search_method",
        "label": "Sitewide Search Method",
        "options": [
          {
            "value": "standard",
            "label": "Standard"
          },
          {
            "value": "klevu",
            "label": "Klevu"
          }
        ],
        "default": "klevu"
      }
    ]
  },
  {
    "name": "Klevu AI",
    "settings": [
      {
        "type": "header",
        "content": "Swatches"
      },
      {
        "type": "select",
        "id": "klevu_swatch_utilisation",
        "options": [
          {
            "value": "variant-images",
            "label": "Variant Images"
          },
          {
            "value": "section-blocks",
            "label": "Section Blocks"
          }
        ],
        "label": "Swatch Utilisation"
      },
      {
        "type": "number",
        "id": "klevu_swatch_limit",
        "label": "Swatch Limit",
        "info": "Limits the amount of swatches to show, set to 0 or leave empty to show all swatches",
        "default": 0
      }
    ]
  },
  {
    "name": "Predictive Search API",
    "settings": [
      {
        "type": "range",
        "id": "predictive_search_limit",
        "min": 2,
        "max": 10,
        "step": 1,
        "label": "Number of results to show",
        "default": 5
