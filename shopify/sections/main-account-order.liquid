{% render 'theme_assets' with 'section-order.min.css' %}

{%- liquid
  render 'section_spacing-and-color', section: section
  render 'section_header', section: section, to_replace: '[[order_number]]', replace_with: order.name

  # Order
  assign order_block = section.blocks | where: 'type', 'order' | first
-%}

{%- if order_block -%}
  <div class="lg:max-w-5xl">
    <div class="grid grid-cols-2 gap-4">
      {%- # Date -%}
      <div>
        <p class="pb-1 font-bold">
          {{- 'sections.main_account_order.date' | t -}}
        </p>
        <p class="text-md">
          {{- order.created_at | date: '%B %d, %Y' -}}
        </p>
      </div>

      {%- # Status -%}
      <div>
        <p class="pb-1 font-bold">
          {{- 'sections.main_account_order.status' | t -}}
        </p>
        <p class="text-md">
          {{- order.fulfillment_status | capitalize -}}
        </p>
      </div>

      {%- # Tracking Number -%}
      {%- liquid
        assign tracking_number = ''
        assign tracking_link = ''

        for line_item in order.line_items
          if forloop.first
            if line_item.fulfillment.tracking_number
              assign tracking_number = line_item.fulfillment.tracking_number
              assign tracking_link = line_item.fulfillment.tracking_number
            endif
          endif
        endfor
      -%}

      {%- if tracking_number != blank -%}
        <div>
          <p class="pb-1 font-bold">
            {{- 'sections.main_account_order.tracking' | t -}}
          </p>

          <a
            class="underline text-md hover:no-underline underline-offset-4"
            href="{{ tracking_link }}"
            {%- if tracking_number == blank -%}
              {%- if order.fulfillment_status == 'fulfilled' -%}
                title="{{- 'sections.main_account_order.tracking_not_available' | t }}"
              {%- else -%}
                title="{{- 'sections.main_account_order.tracking_not_available_yet' | t }}"
              {%- endif -%}
              disabled
            {%- endif -%}
          >
            {{- tracking_number -}}
          </a>
        </div>
      {%- endif -%}
    </div>

    <hr class="my-6 o-hr">

    {%- # Addresses -%}
    {%- if order.billing_address != blank or order.shipping_address != blank -%}
      <div class="grid grid-cols-2 gap-4">
        {%- if order.billing_address != blank -%}
          <div class="lg:w-1/2">
            <p class="pb-1 font-bold">
              {{- 'sections.main_account_order.billing_address' | t -}}
            </p>
            {{- order.billing_address | format_address | replace: '<p', '<p class="text-md"' -}}
          </div>
        {%- endif -%}

        {%- if order.shipping_address != blank -%}
          <div class="lg:w-1/2">
            <p class="pb-1 font-bold">
              {{- 'sections.main_account_order.shipping_address' | t -}}
            </p>
            {{- order.shipping_address | format_address | replace: '<p', '<p class="text-md"' -}}
          </div>
        {%- endif -%}
      </div>

      <hr class="my-6 o-hr">
    {%- endif -%}

    <div class="p-6 border border-solid border-border-light rounded-ss-1 rounded-se-1">
      <p class="font-bold">
        {{- 'sections.main_account_order.summary' | t -}}
      </p>
    </div>

    <ul class="flex flex-col w-full border-l border-r border-solid border-border-light">
      {%- for line_item in order.line_items -%}
        <li class="px-6 pb-6 mb-6 border-b border-solid last:mb-0 first:pt-6 border-border-light">
          <a
            class="flex transition-opacity gap-x-4 hover:opacity-75"
            href="{{ line_item.product.url }}"
          >
            <div class="relative">
              <p class="absolute flex items-center justify-center w-6 h-6 leading-none bg-white border border-solid rounded-full select-none text-primary text-md -left-2 -top-2 z-1 border-border-light">
                {{- line_item.quantity -}}
              </p>
              {%- render 'object_image' with line_item.image, width: 64, height: 64, aspect: '1 / 1' -%}
            </div>

            <div class="flex justify-between w-full">
              <div>
                <p class="font-bold md:text-lg">
                  {{- line_item.product.title -}}
                </p>

                {%- if line_item.product.has_only_default_variant == false or line_item.properties != blank -%}
                  <dl class="text-section-secondary text-md">
                    {%- if line_item.product.has_only_default_variant == false -%}
                      {%- for option in line_item.options_with_values -%}
                        <dt class="sr-only">{{ option.name }}:</dt>
                        <dd class="inline">
                          {{ option.value -}}
                          {%- unless forloop.last %}
                            <span aria-hidden="true">/</span>
                          {% endunless %}
                        </dd>
                      {%- endfor -%}
                    {%- endif -%}

                    {%- for property in line_item.properties -%}
                      {%- assign property_first_char = property.first | slice: 0 -%}
                      {%- if property.last != blank and property_first_char != '_' -%}
                        <div>
                          <dt class="inline">{{ property.first }}:</dt>
                          <dd class="inline">{{ property.last }}</dd>
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </dl>
                {%- endif -%}
              </div>

              <p class="font-bold md:text-lg">
                {{- line_item.quantity | times: line_item.price | money -}}
              </p>
            </div>
          </a>
        </li>
      {%- endfor -%}
    </ul>

    <ul class="flex flex-col w-full p-6 border-solid border-x border-border-light gap-y-2">
      {%- # Subtotal -%}
      <li class="flex justify-between text-md">
        <p>{{- 'sections.main_account_order.subtotal' | t -}}</p>
        <p>{{- order.subtotal_price | money -}}</p>
      </li>

      {%- # Shipping Methods -%}
      {%- for shipping_method in order.shipping_methods -%}
        <li class="flex justify-between text-md">
          <p>
            {{- 'sections.main_account_order.shipping' | t }}
            {{ shipping_method.title | prepend: '(' | append: ')' -}}
          </p>
          <p>{{- shipping_method.price | money -}}</p>
        </li>
      {%- endfor -%}

      {%- # Taxes -%}
      {%- for tax_line in order.tax_lines -%}
        <li class="flex justify-between text-md">
          <p>
            {{- 'sections.main_account_order.tax' | t }} (
            {{- tax_line.title }}
            {{ tax_line.rate | times: 100 -}}
            %)
          </p>
          <p>{{- tax_line.price | money -}}</p>
        </li>
      {%- endfor -%}

      {%- # Discounts -%}
      {%- if order.discounts.size > 0 -%}
        {%- for discount in order.discounts -%}
          <li class="flex justify-between text-md">
            <p>
              {%- liquid
                echo 'sections.main_account_order.discount' | t: number: forloop.index

                if discount.code != blank
                  echo discount.code | prepend: '(' | append: ')'
                endif
              -%}
            </p>

            <p>
              {%- liquid
                # Changes £-50.00 to -£50.00
                assign currency_icon = discount.savings | money | slice: 0
                assign minus_then_currency = currency_icon | prepend: '-'
                assign savings = discount.savings | money_without_currency | replace: '-', ''

                echo minus_then_currency | append: savings
              -%}
            </p>
          </li>
        {%- endfor -%}
      {%- endif -%}
    </ul>

    <div class="w-full p-6 border border-solid border-border-light rounded-es-1 rounded-ee-1">
      {%- # Total -%}
      <div class="flex justify-between text-lg font-bold">
        <p>
          {{- 'sections.main_account_order.total' | t -}}
        </p>
        <p>
          {{- order.total_price | money -}}
        </p>
      </div>
    </div>
  </div>
{%- endif -%}
