{%- liquid
  render 'section_spacing-and-color', section: section

  # Media Aspect Ratios
  capture media_aspect
    render 'section_aspect-ratios', target: section.settings
  endcapture

  # Grid Spacing, Structure
  render 'section_grid', section: section
-%}

{%- # Product Grid -%}
{%- capture product_grid -%}
  <div
    class="js-paginatable js-products"
    section="{{ section.id }}"
  >
    {%- assign page_size = section.settings.pagination_amount -%}
    {%- paginate collection.products by page_size -%}
      <div class="mb-11 lg:mb-13 js-product-grid">
        {%- if collection.products.size == 0 -%}
        <h2 class="flex items-center justify-center text-center pt-7 h-17 font-heading">
            {{- 'sections.main_collection_products.results.none' | t -}}
          </h2>
        {%- else -%}
          <ul class="grid section-grid js-paginatable-list">
            {%- for product in collection.products -%}
              <li class="js-paginatable-item">
                {%- render 'card_product', product: product, aspect_ratio: media_aspect -%}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      {%- liquid
        # Converts string to integer
        assign pagination_visibility = settings.pagination_visibility | plus: 0

        if paginate.pages > pagination_visibility
          case section.settings.pagination_style
            when 'text'
              render 'pagination_text', paginate: paginate
            when 'dynamic'
              render 'pagination_dynamic', paginate: paginate
          endcase
        endif
      -%}
    {%- endpaginate -%}
  </div>
{%- endcapture -%}

{%- liquid
  # Facets
  case section.settings.facets_layout
    when 'horizontal'
      render 'facets_main-horizontal', section: section, product_grid: product_grid
    when 'vertical'
      render 'facets_main-vertical', section: section, product_grid: product_grid
  endcase
-%}
