{%- render 'section_spacing-and-color', section: section -%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    height: {{ section.settings.spacer_mobile }}px;
  }

  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} {
      height: {{ section.settings.spacer_desktop }}px;
    }
  }
{%- endstyle -%}
