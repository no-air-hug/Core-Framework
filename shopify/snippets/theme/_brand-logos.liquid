{%- comment -%}
  -------------------------------------------------------------------------------
  Theme Brand Logos
  -------------------------------------------------------------------------------
  Accepts
  - target: {Object} the section or block (required)
  - class: {String} Additional class name (optional)
  - styling: {String} Style attribute, useful for color settings (optional)
  - width: {Integer} (optional)
  - height: {Integer} (optional)
  -------------------------------------------------------------------------------
  Usage
  {%- render 'theme_brand-logos',
    target: target,
    class: 'class',
    styling: 'styling',
    width: 16,
    height: 16,
  -%}
  -------------------------------------------------------------------------------
  Description
  Renders a brand logo, designed for use with the brandLogos.js part.
{%- endcomment -%}

{%- liquid
  assign target = target | default: section
  assign styling = styling
  assign preload = preload | default: false
  assign class = class | default: 'w-fit'
  assign img_class = img_class | default: 'o-img--contain w-fit rounded-[20%]'
  assign logo_colour = logo_colour | default: target.settings.logo_colour

  # Default Colour #
  assign class = class | prepend: 'o-icon '
-%}

{%- if section.settings.brand_image != blank -%}
  {%- render 'object_image' with section.settings.brand_image,
    height: 50,
    width: 50,
    img_class: img_class,
    preload: preload
  -%}
{%- else -%}
  {%- case section.settings.brand_logo -%}
    {%- when 'standard-logo' -%}
      <svg
        class="{{ class }}"
        style="{{ styling }}"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 200 200"
        fill="none"
        width="{{ width | default: 200 }}"
        height="{{ height | default: 200 }}"
      >
        <circle cx="100" cy="100" r="95" stroke="#FF4500" stroke-width="5" fill="none"/>
        <rect x="60" y="60" width="80" height="50" fill="{{ logo_colour }}" rx="5"/>
        <rect x="75" y="120" width="50" height="10" fill="{{ logo_colour }}" rx="2"/>
        <circle cx="100" cy="145" r="5" fill="{{ logo_colour }}"/>
        <rect x="70" y="70" width="60" height="30" fill="#FFFFFF" rx="3"/>
        <circle cx="130" cy="85" r="3" fill="{{ logo_colour }}"/>
      </svg>
  {%- endcase -%}
{%- endif -%}
