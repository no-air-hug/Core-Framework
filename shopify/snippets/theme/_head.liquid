{%- comment -%}
  -------------------------------------------------------------------------------
  Theme - Head
  -------------------------------------------------------------------------------
  Usage
  {%- render 'theme_head' -%}
  -------------------------------------------------------------------------------
  Description
  The theme's head content - scripts, fonts, etc.
{%- endcomment -%}

{%- liquid
  assign header_font = settings.type_header_font
  assign body_font = settings.type_body_font
%}

{%- # Preload asset filter not possible here due to the usage of font_url -%}
{%- # theme-check-disable -%}

<link rel="preload" href="{{ header_font | font_url: 'woff2' }}" as="font" type="font/woff2" crossorigin>
{% if body_font.family != header_font.family and body_font.weight != header_font.weight %}
  <link rel="preload" href="{{ body_font | font_url: 'woff2' }}" as="font" type="font/woff2" crossorigin>
{% endif %}

{%- # theme-check-enable -%}

{%- # prettier-ignore -%}
<script type="text/javascript">
  Shopify.moneyFormat = {{ shop.money_format | json }};
  Shopify.routes = {
    ...Shopify.routes,
    cartUrl: {{ routes.cart_url | json }},
    cartAddUrl: {{ routes.cart_add_url | json }},
    cartChangeUrl: {{ routes.cart_change_url | json }},
    cartUpdateUrl: {{ routes.cart_update_url | json }},
    predictiveSearchUrl: {{ routes.predictive_search_url | json }},
  }
  Shopify.theme.i18n = {
    addToCart: {{ 'global.products.add_to_cart_price_html' | t | json }},
    soldOut: {{ 'global.products.sold_out' | t | json }},
    unavailable: {{ 'global.products.unavailable' | t | json }},
    cart: {
      error: {{ 'global.cart.errors.general' | t | json }},
      quantityError: {{ 'global.cart.errors.quantity_html' | t: quantity: '[quantity]' | json }},
    },
    shareSuccess: {{ 'global.social.share.success_message' | t | json }},
    global: {
      dialogs: {
        accessibility: {
          actions: {
          open: {{ 'global.dialogs.accessibility.actions.open' | t | json }},
            close: {{ 'global.dialogs.accessibility.actions.close' | t | json }}
          }
        }
      }
    }
  };
</script>

{%- liquid
  if settings.sitewide_search_method == 'klevu'
    render 'klevu_config'
  endif
-%}

{%- style -%}
  {% for font in header_font.variants %}
    {{ font | font_face: font_display: 'swap' }}
  {% endfor %}

  {% if body_font.family != header_font.family %}
    {% for font in body_font.variants %}
      {{ font | font_face: font_display: 'swap' }}
    {% endfor %}
  {% endif %}

  :root {
    /* Layout */
    --base-space: 24px;
    --page-width: 1680;
    --page-space: clamp(var(--base-space), 8.21vw + -1rem, 12.8rem);
    --gap: clamp(2.4rem, 1.26vw + 1.88rem, 4rem);

    /* Typography */
    --font-primary: {{ body_font.family }}, {{ body_font.fallback_families }};
    --font-secondary: {{ header_font.family }}, {{ header_font.fallback_families }};
    --base-font-size: 1.6rem;
    --base-line-height: 1.5;

    /* Colors */
    --c-highlight: {{ settings.colors_highlight }};

    --c-primary: {{ settings.colors_primary }};
    --c-primary-inverse: {{ settings.colors_primary_inverse }};
    --c-secondary: {{ settings.colors_secondary }};
    --c-secondary-inverse: {{ settings.colors_secondary_inverse }};

    --c-border-light: {{ settings.colors_border_light }};
    --c-border-dark: {{ settings.colors_border_dark }};

    --c-pricing-sale: {{ settings.colors_pricing_sale }};
    --c-pricing-compare: {{ settings.colors_pricing_compare }};
    --c-pricing-sale-inverse: {{ settings.colors_pricing_sale_inverse }};
    --c-pricing-compare-inverse: {{ settings.colors_pricing_compare_inverse }};

    /* Buttons */
    --buttons-border-width: {{ settings.buttons_border_thickness }}px;
    --buttons-radius: {{ settings.buttons_border_radius }}px;
    --buttons-primary-color: {{ settings.buttons_primary_color }};
    --buttons-primary-color-hover: {{ settings.buttons_primary_color_hover }};
    --buttons-primary-color-active: {{ settings.buttons_primary_color_active }};
    --buttons-primary-color-focus: {{ settings.buttons_primary_color_focus }};
    --buttons-primary-color-disabled: {{ settings.buttons_primary_color_disabled }};
    --buttons-primary-bg: {{ settings.buttons_primary_bg }};
    --buttons-primary-bg-hover: {{ settings.buttons_primary_bg_hover }};
    --buttons-primary-bg-active: {{ settings.buttons_primary_bg_active }};
    --buttons-primary-bg-focus: {{ settings.buttons_primary_bg_focus }};
    --buttons-primary-bg-disabled: {{ settings.buttons_primary_bg_disabled }};
    --buttons-primary-border: {{ settings.buttons_primary_border }};
    --buttons-primary-border-hover: {{ settings.buttons_primary_border_hover }};
    --buttons-primary-border-active: {{ settings.buttons_primary_border_active }};
    --buttons-primary-border-focus: {{ settings.buttons_primary_border_focus }};
    --buttons-primary-border-disabled: {{ settings.buttons_primary_border_disabled }};

    --buttons-secondary-color: {{ settings.buttons_secondary_color }};
    --buttons-secondary-color-hover: {{ settings.buttons_secondary_color_hover }};
    --buttons-secondary-color-active: {{ settings.buttons_secondary_color_active }};
    --buttons-secondary-color-focus: {{ settings.buttons_secondary_color_focus }};
    --buttons-secondary-color-disabled: {{ settings.buttons_secondary_color_disabled }};
    --buttons-secondary-bg: {{ settings.buttons_secondary_bg }};
    --buttons-secondary-bg-hover: {{ settings.buttons_secondary_bg_hover }};
    --buttons-secondary-bg-active: {{ settings.buttons_secondary_bg_active }};
    --buttons-secondary-bg-focus: {{ settings.buttons_secondary_bg_focus }};
    --buttons-secondary-bg-disabled: {{ settings.buttons_secondary_bg_disabled }};
    --buttons-secondary-border: {{ settings.buttons_secondary_border }};
    --buttons-secondary-border-hover: {{ settings.buttons_secondary_border_hover }};
    --buttons-secondary-border-active: {{ settings.buttons_secondary_border_active }};
    --buttons-secondary-border-focus: {{ settings.buttons_secondary_border_focus }};
    --buttons-secondary-border-disabled: {{ settings.buttons_secondary_border_disabled }};

    --buttons-tertiary-color: {{ settings.buttons_tertiary_color }};
    --buttons-tertiary-color-hover: {{ settings.buttons_tertiary_color_hover }};
    --buttons-tertiary-color-active: {{ settings.buttons_tertiary_color_active }};
    --buttons-tertiary-color-focus: {{ settings.buttons_tertiary_color_focus }};
    --buttons-tertiary-color-disabled: {{ settings.buttons_tertiary_color_disabled }};
    --buttons-tertiary-bg: {{ settings.buttons_tertiary_bg }};
    --buttons-tertiary-bg-hover: {{ settings.buttons_tertiary_bg_hover }};
    --buttons-tertiary-bg-active: {{ settings.buttons_tertiary_bg_active }};
    --buttons-tertiary-bg-focus: {{ settings.buttons_tertiary_bg_focus }};
    --buttons-tertiary-bg-disabled: {{ settings.buttons_tertiary_bg_disabled }};
    --buttons-tertiary-border: {{ settings.buttons_tertiary_border }};
    --buttons-tertiary-border-hover: {{ settings.buttons_tertiary_border_hover }};
    --buttons-tertiary-border-active: {{ settings.buttons_tertiary_border_active }};
    --buttons-tertiary-border-focus: {{ settings.buttons_tertiary_border_focus }};
    --buttons-tertiary-border-disabled: {{ settings.buttons_tertiary_border_disabled }};

    --buttons-underline-color: {{ settings.buttons_underline_color }};
    --buttons-underline-color-hover: {{ settings.buttons_underline_color_hover }};
    --buttons-underline-color-active: {{ settings.buttons_underline_color_active }};
    --buttons-underline-color-focus: {{ settings.buttons_underline_color_focus }};
    --buttons-underline-color-disabled: {{ settings.buttons_underline_color_disabled }};
  }

  /*
    Remove all the styles of the "User-Agent-Stylesheet", except for the 'display' property
    - The "symbol *" part is to solve Firefox SVG sprite bug
  */
  *:where(:not(html, iframe, canvas, img, svg, video, audio):not(svg *, symbol *)) {
    all: unset;
    display: revert;
  }

  /* Preferred box-sizing value */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  /* Reapply the pointer cursor for anchor tags */
  a,
  button {
    display: inline-flex;
    cursor: revert;
  }

  /* Remove list styles (bullets/numbers) */
  ol,
  ul,
  menu {
    list-style: none;
  }

  /* For images to not be able to exceed their container */
  picture,
  video,
  img {
    display: block;
    max-width: 100%;
    height: auto;
  }

  svg {
    flex-shrink: 0;
    max-width: 100%;
    max-height: 100%;
  }

  /* removes spacing between cells in tables */
  table {
    border-collapse: collapse;
  }

  /* Safari - solving issue when using user-select:none on the <body> text input doesn't working */
  input,
  textarea {
    -webkit-user-select: auto;
  }

  /* revert the 'white-space' property for textarea elements on Safari */
  textarea {
    white-space: revert;
  }

  /* minimum style to allow to style meter element */
  meter {
    -webkit-appearance: revert;
    appearance: revert;
  }

  /* reset default text opacity of input placeholder */
  ::placeholder {
    color: unset;
  }

  /* fix the feature of 'hidden' attribute.
   display:revert; revert to element instead of attribute
  */
  :where([hidden]) {
    display: none !important;
  }

  /* revert for bug in Chromium browsers
   - fix for the content editable attribute will work properly.
   - webkit-user-select: auto; added for Safari in case of using user-select:none on wrapper element
  */
  :where([contenteditable]:not([contenteditable='false'])) {
    -moz-user-modify: read-write;
    -webkit-user-modify: read-write;
    overflow-wrap: break-word;
    -webkit-line-break: after-white-space;
    -webkit-user-select: auto;
  }

  /* apply back the draggable feature - exist only in Chromium and Safari */
  :where([draggable='true']) {
    -webkit-user-drag: element;
  }

  html {
    height: 100%;
    color: #222222;
    font-size: 62.5%;
    -webkit-text-size-adjust: 100%;
    -ms-text-size-adjust: 100%;
    scroll-padding-top: var(--header-height);
  }

  body {
    font-family: var(--font-primary);
    font-size: var(--base-font-size);
    line-height: var(--base-line-height);
    text-rendering: optimizeSpeed;
  }

  :where(h1, h2, h3, h4, h5, h6) {
    word-break: break-word;
  }

  :where(summary[class])::-webkit-details-marker {
    display: none;
  }

  mark {
    all: revert;
  }

  a,
  button,
  [type="button"],
  [type="submit"] {
    cursor: pointer;
  }

  b,
  strong {
    font-weight: bold
  }

  em,
  i {
    font-style: italic;
  }

  small {
    font-size: 80%;
  }

  s {
    text-decoration: revert;
  }
{%- endstyle -%}

{% if request.path == '/challenge' %}
  <style>
    .shopify-challenge__container {
      padding: 80px;
    }

    .shopify-challenge__message {
      margin-bottom: 24px;
    }

    form .g-recaptcha {
      margin-bottom: 24px;
    }

    .shopify-challenge__button {
      padding: 14px 16px 13px;
      border: var(--buttons-border-width) solid;
      border-color: var(--buttons-primary-bg);
      border-radius: var(--buttons-radius);
      background-color: var(--buttons-primary-bg);
      color: var(--buttons-primary-color);
      font-weight: bold;
      font-size: 1.4rem;
      line-height: normal;
      letter-spacing: -0.02em;
    }
  </style>
{% endif %}
