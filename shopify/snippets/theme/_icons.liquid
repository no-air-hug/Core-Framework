{% # theme-check-disable TemplateLength %}
{%- comment -%}
  -------------------------------------------------------------------------------
  Theme Icons (Base Theme)
  -------------------------------------------------------------------------------
  Accepts
  - class: {String} Additional class name (optional)
  - styling: {String} Style attribute, useful for color settings (optional)
  - highlight_icon: {Boolean} applies the global highlight color to the icon
  - width: {Integer} (optional)
  - height: {Integer} (optional)
  -------------------------------------------------------------------------------
  Usage
  {%- render 'theme_icons',
    icon: 'icon',
    classes: 'classes',
    styling: 'styling',
    highlight_icon: highlight_icon,
    width: 16,
    height: 16,
  -%}
  -------------------------------------------------------------------------------
  Description
  Renders a icon
{%- endcomment -%}

{%- liquid
  assign styling = styling
  assign highlight_icon = highlight_icon

  # Default Colour #
  assign class = class | prepend: 'o-icon '

  if highlight_icon
    assign class = class | append: ' stroke-highlight'
  endif

  unless class contains 'stroke'
    assign class = class | append: ' stroke-black'
  endunless

  assign theme_icons = theme_icons | downcase
-%}

