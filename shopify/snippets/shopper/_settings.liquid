{%- comment -%}
  ---------------------------------------------------------------------------
  Json data for Shopper App
  ---------------------------------------------------------------------------
{%- endcomment -%}
{%- liquid
  assign webstring = '/?isWebView=true'
  assign markets = section.blocks | where: 'type', 'market'
  assign account_links = section.blocks | where: 'type', 'account'
-%}
<script>
  {
    "countrySelector": [
    {%- for market in markets -%}
      {
        "country": {{ market.settings.title | json }},
        "countryCode": {{ market.settings.code | json }},
        "URL":{{ market.settings.domain | json }}
        }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
    ],
    "swipeToLikeCategories": [
    {%- for selected_collection in section.settings.swipe_to_like -%}
      {
        "title": {{ selected_collection.title | json }},
        "cgid": {{ selected_collection.id | prepend: 'gid://shopify/Collection/' | json }}
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
    ],
    "myAccountLinks": [
      {
        "title": {{ shop.name | capitalize | json }},
        "platform": "both",
        "url":{{ shop.secure_url | json }}
      },
      {
        "title": "My Account",
        "platform": "both",
        "url":  {{ shop.secure_url | append: routes.account_url | append: webstring | json }},
        "type": "details"
      },
      {
        "title": "My Orders",
        "platform": "both",
        "url": {{ shop.secure_url | append: routes.account_url | append: "/orders" | append: webstring | json }},
        "type": "purchase"
      },
      {
        "title": "My Addresses",
        "platform": "both",
        "url": {{ shop.secure_url | append: routes.account_url | append: "/addresses" | append: webstring | json }}
      }{%- if account_links -%},{%- endif -%}

      {%- if account_links -%}
        {%- for link in account_links -%}
          {
            "title": {{ link.settings.title | json }},
            "platform": {{ link.settings.platform | json }},
            "url": {{ link.settings.url  | prepend: shop.secure_url | append: webstring | json }}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
    ],
      "appHomepageURL": {{ shop.secure_url | append: webstring | json }},
      "iOSAppVersion": {{ section.settings.ios_version | json }},
      "androidAppVersion": {{ section.settings.android_version | json }}
  }
</script>
