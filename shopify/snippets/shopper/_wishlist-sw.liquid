{% comment %}
  --------------------------------------------------------------------
      Functions for handling Smartwishlist App into Shopper
  --------------------------------------------------------------------
{% endcomment %}
<script>
  let wishlistID = '';
  let customer = true;

  function SWCallbackWishlistButtonLoaded() {
    wishlistID = SWGetCustomerWishlistId();
    if (wishlistID == 0) {
      wishlistID = SWGetExpressWishlistId();
      customer = false;
    }
    // Update hidden Shopper fields onload
    document.querySelector('#guestProductListID').value = wishlistID;
    fetchWishlistCount(customer, wishlistID);
    console.log('wishlistID top', wishlistID);
  }
  //------------------------------------------------------
  // If customer not logged in use the following
  //------------------------------------------------------
  function SWCallbackExpressWishlistProductItemAdded() {
    console.log('SWCallbackExpressWishlistProductItemAdded');
    fetchWishlistCount(customer, wishlistID);
  }

  function SWCallbackExpressWishlistCollectionItemAdded() {
    console.log('SWCallbackExpressWishlistCollectionItemAdded');
    fetchWishlistCount(customer, wishlistID);
  }

  function SWCallbackExpressWishlistProductItemRemoved() {
    console.log('SWCallbackExpressWishlistProductItemRemoved');
    fetchWishlistCount(customer, wishlistID);
  }

  function SWCallbackExpressWishlistCollectionItemRemoved() {
    console.log('SWCallbackExpressWishlistCollectionItemRemoved');
    fetchWishlistCount(customer, wishlistID);
  }

  //------------------------------------------------------
  //  If customer logged in use the following
  //------------------------------------------------------
  function SWCallbackCustomerWishlistProductItemAdded() {
    console.log('SWCallbackCustomerWishlistProductItemAdded');
    fetchWishlistCount(customer, wishlistID);
  }
  function SWCallbackCustomerWishlistCollectionItemAdded() {
    console.log('SWCallbackCustomerWishlistCollectionItemAdded');
    fetchWishlistCount(customer, wishlistID);
  }
  function SWCallbackCustomerWishlistProductItemRemoved() {
    console.log('SWCallbackCustomerWishlistProductItemRemoved');
    fetchWishlistCount(customer, wishlistID);
  }
  function SWCallbackCustomerWishlistCollectionItemRemoved() {
    console.log('SWCallbackCustomerWishlistCollectionItemRemoved');
    fetchWishlistCount(customer, wishlistID);
  }

  //------------------------------------------------------
  //  Item removed from wishlist page
  //------------------------------------------------------
  function WishlistLoadedCallback() {
    const wishList = document.querySelector('.wishlistbodycontainer');
    wishList.addEventListener(
      'click',
      (e) => e.target.closest('.removebutton') && fetchWishlistCount(customer, wishlistID),
    );
  }
  async function fetchWishlistCount(customer, id) {
    const type = customer ? 'customerid' : 'wishlistid';
    const url = `/a/wishlist?type=api&${type}=${id}&version=1`;

    await fetch(url, {
      method: 'GET',
      cache: 'no-cache',
      headers: {
        'Content-Type': 'application/json',
      },
    })
      .then((res) => res.json())
      .then((data) => updateWishlistCount(data.count));
  }

  function updateWishlistCount(count) {
    console.log('updateWishlistCount');
    const data = {
      event: 'wishlistItemsCount',
      value: count,
    };
    // Send notification to shopper app
    if (window.webkit && window.webkit.messageHandlers) {
      window.webkit.messageHandlers.webViewBridge.postMessage(JSON.stringify(data));
    } else if (typeof window.webViewBridge !== 'undefined') {
      window.webViewBridge.postMessage(JSON.stringify(data));
    }

    document.querySelector('#webviewWishlistItemsCount').value = count;
  }

  //------------------------------------------------------
  // Custom events to reload wishlist base them specific
  //------------------------------------------------------
  document.addEventListener('Facets:Update', function () {
    if (typeof ReloadSmartWishlist !== 'undefined' && $.isFunction(ReloadSmartWishlist)) ReloadSmartWishlist();
  });

  document.addEventListener('Pagination:Update', function () {
    if (typeof ReloadSmartWishlist !== 'undefined' && $.isFunction(ReloadSmartWishlist)) ReloadSmartWishlist();
  });
</script>
