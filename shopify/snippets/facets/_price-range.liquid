{%- comment -%}
  -------------------------------------------------------------------------------
  Facets - Price Range
  -------------------------------------------------------------------------------
  Accepts
  - filter: {Object} (required)
  - form_id: {String} - attatches every input to an external form (optional)
  - input_scope: {String} used with the Facets.js file, this declares whether
  the input should be active on mobile or on desktop, possible values are
  limited to 'desktop' or 'mobile' (required).
  -------------------------------------------------------------------------------
  Usage
  {%- render 'facets_price-range',
  filter: filter,
  form_id: 'form',
  input_scope: 'input_scope',
  -%}
  -------------------------------------------------------------------------------
  Description
  Displays the price range filter on the collection and search templates.
{%- endcomment -%}

{%- liquid
  assign filter = filter
  assign form_id = form_id
  assign input_scope = input_scope | default: 'desktop'
  assign input_js_class = input_js_class | default: 'js-facet-input-' | append: input_scope

  assign currencies_using_comma_decimals = 'ANG,ARS,BRL,BYN,BYR,CLF,CLP,COP,CRC,CZK,DKK,EUR,HRK,HUF,IDR,ISK,MZN,NOK,PLN,RON,RUB,SEK,TRY,UYU,VES,VND' | split: ','
  assign uses_comma_decimals = false

  if currencies_using_comma_decimals contains cart.currency.iso_code
    assign uses_comma_decimals = true
  endif
-%}

<header class="flex select-none items-center justify-between border-b border-solid border-border-light py-4 text-sm lg:px-5 lg:text-md">
  <p class="text-md font-bold">
    {{- filter.label -}}
  </p>

  {%- liquid
    assign has_active_facet = false

    if filter.min_value.value != null or filter.max_value.value != null
      assign has_active_facet = true
    endif
  -%}

  {%- if has_active_facet -%}
    <a class="js-facet-remove underline underline-offset-4 hover:no-underline" href="{{ filter.url_to_remove }}">
      {{- 'snippets.facets.price_range.reset' | t -}}
    </a>
  {%- endif -%}
</header>

<price-range class="js-price-range flex flex-col gap-y-6 py-4 lg:px-5" price-gap="10">
  {%- liquid
    # Note: ensure | ceil occurs after replace.
    assign range_max = filter.range_max | money_without_currency | replace: ',', '' | ceil

    assign min_val = filter.min_value.value | money_without_currency | floor | replace: ',', ''
    assign max_val = filter.max_value.value | money_without_currency | default: range_max | replace: ',', '' | ceil

    if uses_comma_decimals
      assign min_val = filter.min_value.value | money_without_currency | floor | replace: '.', '' | replace: ',', '.'
      assign max_val = filter.max_value.value | money_without_currency | default: range_max | replace: '.', '' | replace: ',', '.' | ceil
    endif

    # Set Default
    assign min_val = min_val | default: 0
  -%}

  <div class="flex w-full gap-2">
    <div class="flex flex-col items-start">
      <span class="select-none pb-1 text-sm font-bold">{{- 'snippets.facets.price_range.from' | t -}}</span>
      <input
        class="js-price-input js-price-input-gte h-8 w-17 rounded-1 border text-center {{ input_js_class }}"
        data-input="min"
        data-facets-identifier="{{ filter.min_value.param_name }}-input-min"
        type="number"
        min="0"
        value="{{ min_val | default: 0 }}"
      >
    </div>

    <div class="flex w-6 items-end justify-center pb-[6px] text-lg">-</div>

    <div class="flex flex-col items-start">
      <span class="select-none pb-1 text-sm font-bold">{{- 'snippets.facets.price_range.to' | t -}}</span>
      <input
        class="js-price-input js-price-input-lte h-8 w-17 rounded-1 border text-center {{ input_js_class }}"
        data-input="max"
        data-facets-identifier="{{ filter.max_value.param_name }}-input-max"
        type="number"
        max="{{ range_max }}"
        value="{{ max_val }}"
      >
    </div>
  </div>

  <div class="relative mb-3">
    <div class="relative h-1 rounded-1 bg-grey-80">
      <div class="js-price-progress absolute left-0 right-0 h-full rounded-1 bg-highlight"></div>
    </div>

    <input
      type="range"
      class="js-range-input pointer-events-none absolute top-1/2 h-1 w-full -translate-y-1/2 {{ input_js_class }}"
      data-range="min"
      data-facets-identifier="{{ filter.min_value.param_name }}-range-min"
      name="{{ filter.min_value.param_name }}"
      min="0"
      max="{{ range_max }}"
      value="{{ min_val | default: 0 }}"
      {% if form_id != blank %}
        form="{{ form_id }}"
      {% endif %}
    >
    <input
      type="range"
      class="js-range-input pointer-events-none absolute top-1/2 h-1 w-full -translate-y-1/2 {{ input_js_class }}"
      data-range="max"
      data-facets-identifier="{{ filter.max_value.param_name }}-range-max"
      name="{{ filter.max_value.param_name }}"
      min="0"
      max="{{ range_max }}"
      value="{{ max_val }}"
      {% if form_id != blank %}
        form="{{ form_id }}"
      {% endif %}
    >
  </div>
</price-range>
