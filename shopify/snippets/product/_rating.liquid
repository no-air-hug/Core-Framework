{%- comment -%}
  -------------------------------------------------------------------------------
  Product - Rating
  -------------------------------------------------------------------------------
  Accepts
  - product: {Object} (required)
  -------------------------------------------------------------------------------
  Usage
  {%- render 'product_rating', product: product -%}
  -------------------------------------------------------------------------------
  Description
  Generates a star rating from non-app embed sources
{%- endcomment -%}

{%- if settings.yotpo_star_rating_instance != blank -%}
  <div
    class="yotpo-widget-instance"
    data-yotpo-instance-id="{{ settings.star_rating }}"
    data-yotpo-product-id="{{ product.id }}"
    data-yotpo-section-id="{{ template.name }}"
  ></div>
{%- elsif product.metafields.reviews.rating.value != blank -%}
  <div class="flex items-center text-sm">
    <div class="flex items-center text-sm">
      {% liquid
        assign rating_decimal = 0
        assign decimal = product.metafields.reviews.rating.value.rating | modulo: 1
        if decimal >= 0.3 and decimal <= 0.7
          assign rating_decimal = 0.5
        elsif decimal > 0.7
          assign rating_decimal = 1
        endif
      %}

      <div
        class="rating text-md"
        role="img"
        aria-label="{{ 'global.accessibility.star_reviews_info' | t: rating_value: product.metafields.reviews.rating.value, rating_max: product.metafields.reviews.rating.value.scale_max }}"
      >
        <span
          aria-hidden="true"
          class="rating-star color-icon-{{ settings.accent_icons }}"
          style="--rating: {{ product.metafields.reviews.rating.value.rating | floor }}; --rating-max: {{ product.metafields.reviews.rating.value.scale_max }}; --rating-decimal: {{ rating_decimal }};"
        ></span>
      </div>

      <p class="ml-1 text-sm">
        <span aria-hidden="true">({{ product.metafields.reviews.rating_count }})</span>
        <span class="sr-only">
          {{-
            product.metafields.reviews.rating_count
            | append: ' '
            | append: 'global.accessibility.total_reviews'
            | t
          -}}
        </span>
      </p>
    </div>
  </div>
{%- endif -%}
