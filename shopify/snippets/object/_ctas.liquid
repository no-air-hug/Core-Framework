{%- comment -%}
  -------------------------------------------------------------------------------
  CTAs
  -------------------------------------------------------------------------------
  Accepts
  - settings: {Object} (required) the section or block settings
  - size_mob: {String} (optional) alter the mobile size of the ctas
    ( small, medium, large, full )
  - size_dsk: {String} (optional) alter the desktop size of the ctas
    ( small, medium, large, full )
  - align_mob: {String} (optional) alter the mobile cta alignment
    ( horizontal/vertical )
  - align_dsk: {String} (optional) alter the desktop size of the ctas
    ( small, medium, large, full )
  - class: {String} (optional) add a custom class
  - first_cta_index: {Integer} (optional) generally used to skip a iteration
    in the cta forloop. So if you have two cta settings inside of the schema,
    but you don't want them generated side by side? You would split it into
    two renders, and have the second cta render with the first_cta_index being
    set to 2, and the last_cta_index set to 2.
    - last_cta_index: {Integer} (optional) generate more than a single button. The index
    generated by last_cta_index will correspond to the cta(index: value) set inside
    of the schema.
  - external_button: {Object} (option) insert content from outside of the
    render
  -------------------------------------------------------------------------------
  Usage
  {%- render 'object_ctas' with
    settings: settings,
    class: 'class',
    size_mob: 'small',
    size_dsk: 'large',
    align_mob: 'horizontal',
    align_desktop: 'vertical',
    first_cta_index: first_cta_index,
    last_cta_index: last_cta_index
    external_button: external_button
  -%}
  -------------------------------------------------------------------------------
  Description
  Displays one or two CTA buttons, with the option to add custom icons. For
  use specifically with the ...cta() part utilised in schema files.
{%- endcomment -%}

{%- liquid
  assign class = class
  assign settings = settings | default: block.settings
  assign first_cta_index = first_cta_index | default: 1
  assign last_cta_index = last_cta_index | default: 1

  # Look for available CTA Content
  assign cta_count = 0

  for cta in (first_cta_index..last_cta_index)
    assign index = forloop.index0 | plus: first_cta_index
    assign text_setting = 'cta_' | append: index | append: '_text'

    if settings[text_setting] != blank
      assign cta_count = cta_count | plus: 1
    endif
  endfor

  # Multiple CTAs Class
  if cta_count > 1
    assign class = class | append: ' o-ctas--multiple'
  endif

  # CTA Alignment Classes
  assign align_mob = align_mob | default: settings.cta_align
  assign align_dsk = align_dsk | default: settings.cta_align_desktop

  case align_mob
    when 'horizontal'
      assign class = class | append: ' o-ctas--horizontal-align-mobile'
    when 'vertical'
      assign class = class | append: ' o-ctas--vertical-align-mobile'
    else
      # No alignment settings are available, so assume it's horizontal.
      assign class = class | append: ' o-ctas--horizontal-align-mobile'
  endcase

  case align_dsk
    when 'horizontal'
      assign class = class | append: ' o-ctas--horizontal-align-desktop'
    when 'vertical'
      assign class = class | append: ' o-ctas--vertical-align-desktop'
    else
      # No alignment settings are available, so assume it's horizontal.
      assign class = class | append: ' o-ctas--horizontal-align-desktop'
  endcase

  # External Content
  # - Say if you wanted to integrate a JS button within the boundaries
  # of the 'object_ctas' snippet.
  assign external_button = external_button | default: ''
-%}

{%- if cta_count > 0 -%}
  <div class="o-ctas {{ class }}">
    {%- for cta in (first_cta_index..last_cta_index) -%}
      {%- liquid
        assign index = forloop.index0 | plus: first_cta_index

        assign text_setting = 'cta_' | append: index | append: '_text'
        assign link_style_setting = 'cta_' | append: index | append: '_link_style'
        assign link_setting = 'cta_' | append: index | append: '_link'
        assign target_setting = 'cta_' | append: index | append: '_target'
        assign icon_setting = 'cta_' | append: index | append: '_icon'
        assign icon_position_setting = 'cta_' | append: index | append: '_icon-position'
      -%}

      {%- if settings[text_setting] != blank -%}
        {%- liquid
          capture cta_style
            # Style
            assign link_style = ' o-button--' | append: settings[link_style_setting]

            # Sizing
            assign size_mob = size_mob | default: settings.cta_sizes | default: 'full'
            assign size_dsk = size_dsk | default: settings.cta_sizes_desktop | default: 'medium'

            capture button_size_mob
              case size_mob
                when 'small'
                  echo ' max-md:o-button--small'
                when 'medium'
                  echo ' max-md:o-button--medium'
                when 'large'
                  echo ' max-md:o-button--large'
                when 'full'
                  echo ' max-md:o-button--full'
              endcase
            endcapture

            capture button_size_dsk
              case size_dsk
                when 'small'
                  echo ' md:o-button--small'
                when 'medium'
                  echo ' md:o-button--medium'
                when 'large'
                  echo ' md:o-button--large'
                when 'full'
                  echo ' md:o-button--full'
              endcase
            endcapture

            if settings[link_style_setting] != 'underline'
              echo 'o-button' | append: link_style | append: button_size_mob | append: button_size_dsk
            else
              echo 'o-button' | append: link_style
            endif
          endcapture
        -%}

        <a
          class="{{ cta_style }} o-ctas__cta o-ctas__cta--{{ forloop.index }} flex gap-2"
          {% if settings[link_setting] == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ settings[link_setting] }}"
          {% endif %}
          {% if settings[target_setting] %}
            rel="noreferrer"
            target="_blank"
          {% endif %}
        >
          {%- if settings[icon_setting] != 'none' and settings[icon_position_setting] == 'left' -%}
            <div
              class="min-w-[18px] flex items-center justify-center min-h-[18px] aspect-square o-ctas__cta-icon"
            >
              {%- render 'theme_icons' with settings[icon_setting], width: '1.25em', height: '1.25em' -%}
            </div>
          {%- endif -%}

          <span>
            {{- settings[text_setting] -}}
          </span>

          {%- if settings[icon_setting] != 'none' and settings[icon_position_setting] == 'right' -%}
            <div
              class="min-w-[18px] flex items-center justify-center min-h-[18px] aspect-square o-ctas__cta-icon"
            >
              {%- render 'theme_icons' with settings[icon_setting], width: '1.25em', height: '1.25em' -%}
            </div>
          {%- endif -%}
        </a>
      {%- endif -%}
    {%- endfor -%}

    {{ external_button }}
  </div>
{%- endif -%}
